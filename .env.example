# Generated by: pi-discord setup
# Or edit manually. See: pi-discord help

# Required
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Pi agent configuration
PI_BIN=pi
PI_MODEL=
PI_THINKING=
PI_CWD=/home/ubuntu
PI_EXTRA_FLAGS=

# Gateway behavior
TRIGGER_NAME=Andy
MAX_CONCURRENCY=3
POLL_INTERVAL_MS=1000
SHUTDOWN_TIMEOUT_MS=15000
AUTO_REGISTER_DMS=true
MAX_ATTACHMENT_BYTES=26214400
MAX_TOTAL_ATTACHMENT_BYTES=52428800

# Storage examples
# If left unset, the built-in defaults are under ~/.local/share/pi-discord-gateway/
SESSIONS_DIR=./sessions
DB_PATH=./gateway.db

# Logging
LOG_LEVEL=info
